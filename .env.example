# Copy this file to .env and fill in real values. .env is not committed to git.

# --- SEC EDGAR ---
# SEC's stated policy: requests without a real name + email in the User-Agent
# header get a 403. This is enforcement, not a bug. Put your actual name and a
# real email you'd be fine with SEC seeing in their access logs.
SEC_USER_AGENT="Your Name your.email@example.com"

# --- Postgres / pgvector ---
# Host port is 5433, not 5432, so it doesn't collide with any local Postgres.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=finrisk
DB_USER=finrisk
DB_PASSWORD=finrisk_dev_password

# --- Embeddings ---
# EMBED_DIM must match the VECTOR(n) column in db/init.sql. If you change the
# model to one with a different output dimension, both this value and the SQL
# schema have to change together, and the DB volume needs to be rebuilt.
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384
# "auto" picks mps on Apple Silicon if available, else falls back to cpu.
EMBED_DEVICE=auto

# --- Chunking (chunk.py) ---
# Sizes are in CHARACTERS. ~1000 chars ≈ 250 tokens — comfortably under
# bge-small-en-v1.5's 512-token limit, yet big enough to hold one coherent
# idea. Overlap keeps a sentence that straddles a boundary findable from both
# neighbouring chunks.
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- /ask endpoint (optional — only needed once you call /ask) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
